# Environment Variables

## Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

## OpenAI (para agentes LangGraph)
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENCODE_MODEL=gpt-4o-mini

## OpenCode (modelo gratuito incluido)
OPENCODE_MODEL=minimax-m2.5-free

## GitHub (optional - only for auto-deploy)
GITHUB_TOKEN=your_github_personal_access_token

## Vercel (optional - only for auto-deploy)
VERCEL_API_TOKEN=your_vercel_api_token

## Agents (Python service)
AGENTS_ENABLED=true
AGENTS_URL=http://agents:8000

## Deployment
DEPLOY_ENABLED=true  # Set to false to skip GitHub+Vercel deploy

## Docker
WORKSPACE=/app/workspace
OPENCODE_TIMEOUT=300
